rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection - allow the owner to bootstrap themselves
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (request.auth.uid == userId && request.auth.token.email == 'yilin20020116@gmail.com');
    }

    // News rules
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Cases rules (Match server.ts 'cases' name)
    match /cases/{caseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Qualifications rules
    match /qualifications/{qualId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
