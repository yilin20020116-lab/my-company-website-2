{
  "entities": {
    "News": {
      "title": "News",
      "description": "Company news and announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "News headline" },
        "content": { "type": "string", "description": "News body text" },
        "date": { "type": "string", "format": "date", "description": "Publication date" },
        "category": { "type": "string", "enum": ["公司新闻", "行业动态"], "description": "News category" },
        "imageUrl": { "type": "string", "description": "Main image URL" },
        "summary": { "type": "string", "description": "Short summary for list view" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "date", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "Pipe products and accessories",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "category": { "type": "string", "enum": ["water", "drainage", "accessories"], "description": "Product category ID" },
        "description": { "type": "string", "description": "Product description" },
        "specifications": { "type": "string", "description": "Technical specs" },
        "imageUrl": { "type": "string", "description": "Product thumbnail image URL" },
        "features": { "type": "array", "items": { "type": "string" }, "description": "Key features" }
      },
      "required": ["name", "category", "description"]
    },
    "ProjectCase": {
      "title": "Project Case",
      "description": "Engineering and project showcases",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "location": { "type": "string", "description": "Project location" },
        "date": { "type": "string", "description": "Completion date" },
        "description": { "type": "string", "description": "Project summary" },
        "imageUrl": { "type": "string", "description": "High-res project image" },
        "category": { "type": "string", "description": "Project type" }
      },
      "required": ["title", "imageUrl"]
    },
    "Qualification": {
      "title": "Qualification",
      "description": "Certificates and honors",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Honor/Certificate title" },
        "category": { "type": "string", "enum": ["honors", "qualifications", "patents"], "description": "Category ID" },
        "year": { "type": "string", "description": "Award year" },
        "imageUrl": { "type": "string", "description": "Image of the certificate" }
      },
      "required": ["title", "category", "imageUrl"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Page hero banners",
      "type": "object",
      "properties": {
        "pageId": { "type": "string", "description": "Unique ID for the page (e.g., home, about, qualifications)" },
        "imageUrl": { "type": "string", "description": "Banner background image URL" },
        "title": { "type": "string", "description": "Primary heading text" },
        "subtitle": { "type": "string", "description": "Secondary heading text" },
        "alignment": { "type": "string", "enum": ["top", "center", "bottom"], "description": "Object-fit alignment" }
      },
      "required": ["pageId", "imageUrl"]
    }
  },
  "firestore": {
    "news": { "schema": "News", "description": "Collection for news articles" },
    "products": { "schema": "Product", "description": "Collection for pipe products" },
    "projectCases": { "schema": "ProjectCase", "description": "Collection for successful project deployments" },
    "qualifications": { "schema": "Qualification", "description": "Collection for company honors and certificates" },
    "banners": { "schema": "Banner", "description": "Configuration for page banners" }
  }
}
